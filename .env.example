# =============================================================================
# VideoSDK AI Agents — Environment Variables
# =============================================================================
# Copy this file to `.env` in the repository root and fill in the values for
# the providers used by the example you're running. All variables are read via
# os.getenv(). Only the providers actually referenced by examples in this repo
# are listed below.
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# VideoSDK Auth (REQUIRED — pick ONE of the two setups below)
# -----------------------------------------------------------------------------
# Setup A: Provide a ready-made auth token (generated from the VideoSDK dashboard)
VIDEOSDK_AUTH_TOKEN=

# Setup B: Provide API key + secret. The SDK will auto-mint a JWT at runtime
# and use it for meeting creation, join, recording, SIP, analytics, inference.
# (Used only when VIDEOSDK_AUTH_TOKEN is not set.)
VIDEOSDK_API_KEY=
VIDEOSDK_SECRET_KEY=


# -----------------------------------------------------------------------------
# Provider Keys (only the ones used by examples in this repo)
# -----------------------------------------------------------------------------

# Anam (Avatar — Virtual Avatar/anam_*.py)
ANAM_API_KEY=
ANAM_AVATAR_ID=

# Anthropic (LLM — Pubsub, Reply Interrupt Agent, Wakeup Call, Human In The Loop)
ANTHROPIC_API_KEY=

# AWS Nova Sonic (Realtime — Realtime Pipeline Mode/AWS Nova Sonic)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cartesia (TTS — Recording, Pipeline Hooks, Call Transfer, Multi Agent Switch, Transports, n8n Workflow, Hybrid Mode)
CARTESIA_API_KEY=

# Cerebras (LLM — Fallback Recovery)
CEREBRAS_API_KEY=

# Deepgram (STT — most cascade-pipeline examples)
DEEPGRAM_API_KEY=

# ElevenLabs (TTS — Cascade Pipeline Mode, RAG, Memory, Namo Turn Detector, DTMF Handler, Voice Mail Detector, Reply Interrupt Agent, Pubsub, Room Options, Utterance Handle, Vision, Virtual Avatar)
ELEVENLABS_API_KEY=

# Google (Gemini Live, GoogleLLM, GoogleTTS — A2A, IoT-quickstart, MCP, Realtime Pipeline Mode/Google Gemini, Virtual Avatar realtime examples, Vision, Wakeup Call, Knowledge Base, Conversational Graph, Pipeline Hooks, Recording, Call Transfer, Multi Agent Switch, Transports/videosdk, Human In The Loop, Hybrid Mode)
GOOGLE_API_KEY=

# OpenAI (LLM/STT/TTS/Realtime — A2A, Cascade Pipeline Mode, Background Audio, Memory, RAG, Namo Turn Detector, DTMF Handler, Voice Mail Detector, Conversational Graph, Fallback Recovery, Realtime Pipeline Mode/OpenAI, Room Options, Utterance Handle, Virtual Avatar cascading examples, Transports/websocket, Transports/webrtc, n8n Workflow)
OPENAI_API_KEY=

# Sarvam AI (STT — Hybrid Mode/hybrid_custom_stt_realtime, Knowledge Base, n8n Workflow)
SARVAMAI_API_KEY=

# Simli (Avatar — Virtual Avatar/simli_*.py)
SIMLI_API_KEY=
SIMLI_FACE_ID=

# Ultravox (Realtime — Realtime Pipeline Mode/Ultravox)
ULTRAVOX_API_KEY=

# xAI (LLM — Realtime Pipeline Mode/xAI(Grok), Hybrid Mode/hybrid_realtime_custom_tts)
XAI_API_KEY=


# -----------------------------------------------------------------------------
# Example-specific variables (set only for the example that needs them)
# -----------------------------------------------------------------------------

# Call Transfer — destination phone number or SIP URI to transfer the call to
CALL_TRANSFER_TO=

# Knowledge Base — created in the VideoSDK Dashboard
KNOWLEDGE_BASE_ID=

# Memory (Mem0)
MEM0_API_KEY=
MEM0_DEFAULT_USER_ID=demo-voice-user
MEM0_MEMORY_LIMIT=5

# Human In The Loop — Discord bot
DISCORD_TOKEN=
DISCORD_USER_ID=
DISCORD_CHANNEL_ID=
